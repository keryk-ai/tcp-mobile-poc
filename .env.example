# Secrets are loaded at runtime via Infisical — no .env.local needed.
# Run: npm run dev  (calls `infisical run -- next dev` using .infisical.json)
#
# All variables below are pulled automatically from the TCP project in Infisical (dev env).

# Firebase (in Infisical)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Maps (in Infisical — MAPBOX_TOKEN is server-side key, mapped to NEXT_PUBLIC_ in next.config.ts)
MAPBOX_TOKEN=
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Relay (RELAY_URL defaults to http://localhost:4321 in next.config.ts if not set)
RELAY_URL=
SERVICE_AUTH_KEY=

# svc1-geocoder direct enrich call, used by /api/ta-check for the pre-submit
# TA-eligibility check (dev: http://svc1-geocoder-dev:4449/v1/enrich)
SVC1_ENRICH_URL=

# ElevenLabs (Week 2). ELEVENLABS_API_KEY is server-only — used by
# /api/voice-token to mint per-session conversation tokens for the
# auth-enabled agent (AGE-83); it must never reach the client bundle.
ELEVENLABS_API_KEY=
NEXT_PUBLIC_AWP_AGENT_ID=agent_8301kw2ea0h1ex0af3yjjee8kwef
